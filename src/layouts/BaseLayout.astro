---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'ООО «Дельта-лифт» — монтаж, замена и обслуживание лифтов по всей России с 2003 года. Специализация: нестандартные шахты. Официальный дилер SANYO.' } = Astro.props;

import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<meta name="description" content={description}>
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Onest:wght@300;400;500;600&family=Unbounded:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
<slot />
</body>
</html>
