<script is:inline>
// ── PARALLAX ──────────────────────────────────────────
const pg=document.getElementById('pg'),g1=document.getElementById('g1'),g2=document.getElementById('g2');
const prlGhost=document.getElementById('prl-ghost'),prlLines=document.getElementById('prl-lines');
let tick=false;

window.addEventListener('scroll',()=>{if(!tick){requestAnimationFrame(run);tick=true}},{passive:true});

function run(){
  const sy=window.scrollY;
  if(pg) pg.style.transform=`translateY(${sy*.15}px)`;
  if(g1) g1.style.transform=`translateY(${sy*-.1}px)`;
  if(g2) g2.style.transform=`translateY(${sy*.07}px)`;
  const prlSec=document.getElementById('prl-sec');
  if(prlSec&&prlGhost&&prlLines){
    const r=prlSec.getBoundingClientRect();
    const p=(window.innerHeight-r.top)/(window.innerHeight+r.height);
    const d=(p-.5)*90;
    prlGhost.style.transform=`translateY(calc(-50% + ${d}px))`;
    prlLines.style.transform=`translateY(${d*.35}px)`;
  }
  tick=false;
}
run();

// ── MOUSE PARALLAX ────────────────────────────────────
const hero=document.querySelector('.hero');
if(hero){
  hero.addEventListener('mousemove',e=>{
    const rx=(e.clientX/window.innerWidth-.5)*20,ry=(e.clientY/window.innerHeight-.5)*20;
    if(g1) g1.style.transform=`translate(${rx*1.1}px,${ry*1.1}px)`;
    if(g2) g2.style.transform=`translate(${rx*-.5}px,${ry*-.5}px)`;
    if(pg) pg.style.transform=`translate(${rx*.3}px,${ry*.3}px)`;
  });
  hero.addEventListener('mouseleave',()=>{
    if(g1) g1.style.transform='';
    if(g2) g2.style.transform='';
    if(pg) pg.style.transform='';
  });
}

// ── TESTIMONIAL ROTATOR ───────────────────────────────
