  {
    text:'«Выражаем благодарность ООО «Дельта-лифт» за <em>оперативную организацию работ</em> и качественное выполнение монтажных и пусконаладочных работ управления четырьмя лифтами. Произведённое переключение позволило <em>сократить время ожидания и снизить энергопотребление</em>.»',
    name:'ОАО «Концерн Росэнергоатом»',org:'Руководитель АХО А.А. Гудин · 2014',av:'РЭ'
  },
  {
    text:'«ОАО МГТС сотрудничает с ООО «Дельта-лифт» с 2010 г. ООО «Дельта-лифт» <em>провело замену 12 лифтов</em> в зданиях ОАО МГТС. Работы выполнены качественно. ООО «Дельта-лифт» является <em>надёжным партнёром</em>, добросовестно выполняет договорные обязательства.»',
    name:'ОАО «МГТС»',org:'Директор Департамента В.Е. Николаенко · 2012',av:'МГ'
  },
  {
    text:'«AAB Automatisierungs-und Anlagenbau GmbH благодарит за выполненные <em>строительно-монтажные и пусконаладочные работы</em> в Российском онкологическом научном центре им. Н.Н. Блохина. Все работы произведены <em>профессионально и в срок</em>.»',
    name:'AAB GmbH (Германия)',org:'Генеральный директор В. Фридель · Москва',av:'АА'
  }
];
let current=0,proofTimer;
function setProof(i){
  current=i;
  const t=document.getElementById('proof-text');
  const n=document.getElementById('proof-name');
  const o=document.getElementById('proof-org');
  const a=document.getElementById('proof-avatar');
  t.style.opacity='0';
  setTimeout(()=>{
    t.innerHTML=proofs[i].text;
    n.textContent=proofs[i].name;
    o.textContent=proofs[i].org;
    a.textContent=proofs[i].av;
    t.style.opacity='1';
  },200);
  document.querySelectorAll('.proof-dot').forEach((d,j)=>d.classList.toggle('active',j===i));
  clearInterval(proofTimer);
  proofTimer=setInterval(nextProof,5000);
}
function nextProof(){setProof((current+1)%proofs.length)}
document.getElementById('proof-text').style.transition='opacity .3s ease';
proofTimer=setInterval(nextProof,5000);

// ── COUNT-UP ANIMATION ────────────────────────────────────────
(function(){
  function animateCounter(el, target, suffix, dur) {
    if(window.matchMedia('(prefers-reduced-motion:reduce)').matches){el.textContent=target+suffix;return;}
    const t0=performance.now();
    (function step(now){
      const p=Math.min((now-t0)/dur,1);
      const ease=1-Math.pow(1-p,3);
      el.textContent=Math.round(ease*target)+suffix;
      if(p<1)requestAnimationFrame(step);
    })(t0);
  }
  const obs=new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(!e.isIntersecting||e.target.dataset.counted)return;
      e.target.dataset.counted='1';
      animateCounter(e.target,+e.target.dataset.target,e.target.dataset.suffix||'',1400);
      obs.unobserve(e.target);
    });
  },{threshold:.6});
  document.querySelectorAll('.sn-val[data-target]').forEach(el=>obs.observe(el));
})();
</script>

