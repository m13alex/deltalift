      "telephone": "+78002224230",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Кузнецкий Мост, 21/5, эт. 6",
        "addressLocality": "Москва",
        "postalCode": "107996",
        "addressCountry": "RU"
      }
    }
  ]
}
</script>

<Header activePage="sanyo" />

<SectionNav sections={sectionNavItems} />

<ElevatorSystem />

<main>
<!-- HERO -->
<section class="hero">
  <div class="hero-bg">
    <div class="hero-grid-lines" id="pg"></div>
  </div>
  <div class="container">

    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Главная</a>
      <span class="breadcrumb-sep">›</span>
      <span class="breadcrumb-current">Производитель SANYO</span>
    </nav>

    <div class="hero-inner" style="margin-top:40px">
      <div>
        <div class="hero-label fi">
          <div class="hero-label-dot"></div>
          ОФИЦИАЛЬНЫЙ ДИЛЕР С 2024 ГОДА
        </div>
        <h1 class="hero-h1 fi fi-d1">
          Лифты <em>SANYO</em><br>
          в России — напрямую<br>
          от дилера
        </h1>
        <p class="hero-desc fi fi-d2">
          ООО «Дельта-лифт» — авторизованный дилер SANYO ELEVATOR CO., LTD на территории Российской Федерации. Прямые поставки, гарантийное обслуживание, оригинальные запчасти.
        </p>
        <div class="hero-actions fi fi-d3">
          <a href="/contacts/" class="btn btn-primary btn-lg">
            <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 2v14M2 9h14"/></svg>
            Получить предложение
          </a>
          <a href="#certificate" class="btn btn-outline btn-lg">Сертификат дилера</a>
        </div>
      </div>

      <!-- Dealer certificate card -->
      <div class="cert-card fi fi-d2" id="certificate">
        <div class="cert-logo"><img src="/img/sanyo_logo_blue.png" alt="SANYO" class="sanyo-logo-light" style="height:42px;width:auto"><img src="/img/sanyo_logo_white.png" alt="SANYO" class="sanyo-logo-dark" style="height:42px;width:auto"></div>
        <div class="cert-logo-sub">ELEVATOR CO., LTD · Rising Into The Future</div>
        <div class="cert-divider"></div>
        <div class="cert-row">
          <span class="cert-row-label">Документ</span>
          <span class="cert-row-value">Доверенность дилера</span>
        </div>
        <div class="cert-row">
          <span class="cert-row-label">Реестровый номер</span>
          <span class="cert-row-value">SY-2025010109</span>
        </div>
        <div class="cert-row">
          <span class="cert-row-label">Дата выдачи</span>
          <span class="cert-row-value">1 января 2024 г.</span>
        </div>
        <div class="cert-row">
          <span class="cert-row-label">Подписал</span>
          <span class="cert-row-value">Xie Dezhi, CEO</span>
        </div>
        <div class="cert-row">
          <span class="cert-row-label">Полномочия</span>
          <span class="cert-row-value">Продажа · Монтаж · Ремонт · ТО</span>
        </div>
        <div class="cert-row">
          <span class="cert-row-label">Территория</span>
          <span class="cert-row-value">Российская Федерация</span>
        </div>
        <div class="cert-status">
          <div class="cert-status-dot"></div>
          <div class="cert-status-text">Действующий авторизованный дилер</div>
        </div>
        <div class="cert-ref">Производитель: Huzhou City, Zhejiang Province, China</div>
      </div>
    </div>
  </div>
</section>

<!-- SCALE -->
<section class="scale-section" style="position:relative;overflow:hidden">
  <!-- Blueprint: motor room diagram -->
  <div class="bp" style="right:2%;top:50%;transform:translateY(-50%);opacity:.10">
    <svg width="200" height="80" viewBox="0 0 200 80" fill="none" stroke="currentColor" stroke-width=".8" font-family="monospace">
      <rect x="10" y="10" width="80" height="60" stroke-width="1.2"/>
      <text x="50" y="8" font-size="6" fill="currentColor" stroke="none" text-anchor="middle">МАШИННЫЙ ЗАЛ</text>
      <circle cx="50" cy="40" r="20" stroke-width="1"/>
      <circle cx="50" cy="40" r="8"/>
      <line x1="50" y1="20" x2="50" y2="28"/><line x1="50" y1="52" x2="50" y2="60"/>
      <line x1="30" y1="40" x2="38" y2="40"/><line x1="62" y1="40" x2="70" y2="40"/>
      <rect x="100" y="20" width="90" height="40" stroke-width="1"/>
      <text x="145" y="37" font-size="7" font-weight="700" fill="currentColor" stroke="none" text-anchor="middle">WISE3000</text>
      <text x="145" y="49" font-size="6" fill="currentColor" stroke="none" text-anchor="middle">Система управления</text>
      <line x1="90" y1="40" x2="100" y2="40" stroke-dasharray="2 2"/>
      <text x="50" y="78" font-size="6" fill="currentColor" stroke="none" text-anchor="middle">67 ОФИСОВ · 1020 СЕРВИСНЫХ ЦЕНТРОВ</text>
    </svg>
  </div>
  <div class="container">
    <div class="scale-grid">
      <div class="scale-item fi">
        <div class="scale-num"><span class="sn-val">1998</span><span class="sn-sfx">г</span></div>
        <div class="scale-label">год основания SANYO</div>
      </div>
      <div class="scale-item fi fi-d1">
        <div class="scale-num"><span class="sn-val">67</span><span class="sn-sfx">+</span></div>
        <div class="scale-label">офисов по всему Китаю</div>
      </div>
