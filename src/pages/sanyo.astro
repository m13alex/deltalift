---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ElevatorSystem from '../components/ElevatorSystem.astro';
import SectionNav from '../components/SectionNav.astro';
import ThemeToggleScript from '../components/ThemeToggleScript.astro';
import FadeInScript from '../components/FadeInScript.astro';

const sectionNavItems = [
  { id: 'hero', label: 'О дилере', selector: '.hero' },
  { id: 'scale', label: 'Масштаб', selector: '.scale-section' },
  { id: 'why', label: 'Почему SANYO', selector: '.why-grid' },
  { id: 'fire', label: 'Пожарные', selector: '.fire-section' },
  { id: 'lineup', label: 'Линейка', selector: '#lineup' },
  { id: 'docs', label: 'Документы', selector: '#docs' },
  { id: 'projects', label: 'Объекты', selector: '.projects-grid' },
];
---

<BaseLayout title="Лифты SANYO в России — официальный дилер ООО «Дельта-лифт»" description="ООО «Дельта-лифт» — официальный авторизованный дилер SANYO ELEVATOR CO., LTD в России. Продажа, монтаж, ремонт и техническое обслуживание лифтов SANYO. Сертификат дилера SY-2025010109.">

<style is:global>
/* ─── PAGE-SPECIFIC: LIGHT OVERRIDES ─────────────────── */
[data-theme="light"] .cert-card,[data-theme="light"] .why-card,[data-theme="light"] .project-card{box-shadow:var(--shadow-card)}
[data-theme="light"] .scale-section,[data-theme="light"] .fire-section{background:var(--bg-surface)}
[data-theme="light"] .hero-bg-grid{background-image:linear-gradient(rgba(0,0,0,0.055) 1px,transparent 1px),linear-gradient(90deg,rgba(0,0,0,0.055) 1px,transparent 1px)}
/* ─── PAGE-SPECIFIC: OVERRIDES ───────────────────────── */
.grid-2{gap:24px}
.section{padding:80px 0}

/* ─── HERO ───────────────────────────────────────────── */
.hero{
  padding:40px 0 80px;
  position:relative;overflow:hidden;
}
.hero-bg{
  position:absolute;inset:0;pointer-events:none;
  background:
    radial-gradient(ellipse 60% 50% at 80% 50%, rgba(37,99,235,0.06) 0%, transparent 70%),
    radial-gradient(ellipse 40% 60% at 10% 80%, rgba(212,135,14,0.05) 0%, transparent 70%);
}
.hero-grid-lines{
  position:absolute;inset:0;
  background-image:
    linear-gradient(rgba(255,255,255,0.055) 1px,transparent 1px),
    linear-gradient(90deg,rgba(255,255,255,0.055) 1px,transparent 1px);
  background-size:64px 64px;
  will-change:transform;
}
.hero-inner{position:relative;z-index:2;display:grid;grid-template-columns:1fr minmax(0,420px);gap:48px;align-items:center}
@media(max-width:900px){.hero-inner{grid-template-columns:1fr}}

.hero-label{
  display:inline-flex;align-items:center;gap:8px;
  border:1px solid var(--info-border);background:var(--info-dim);
  padding:5px 14px;border-radius:99px;
  font-size:11px;color:#60a5fa;font-family:var(--font-display);
  letter-spacing:0.1em;font-weight:500;margin-bottom:24px;
}
.hero-label-dot{width:5px;height:5px;border-radius:50%;background:#60a5fa;animation:pulse 2s ease infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}

.hero-h1{
  font-family:var(--font-display);
  font-size:clamp(30px,4.5vw,54px);font-weight:700;
  line-height:1.05;letter-spacing:-0.02em;
  color:var(--text-primary);margin-bottom:20px;
}
.hero-h1 em{font-style:normal;color:var(--accent)}
.hero-desc{
  font-size:17px;color:var(--text-secondary);
  max-width:480px;line-height:1.7;margin-bottom:32px;
}
.hero-actions{display:flex;gap:12px;flex-wrap:wrap}

/* Dealer cert card */
.cert-card{
  background:var(--bg-surface);
  border:1px solid var(--border-default);
  border-radius:var(--r-2xl);
  padding:32px;
  position:relative;overflow:hidden;
}
.cert-card::before{
  content:'';position:absolute;top:0;left:0;right:0;
  height:3px;background:linear-gradient(90deg,var(--info),#60a5fa);
}
.cert-logo{
  font-family:var(--font-display);font-size:22px;font-weight:700;
  color:#60a5fa;letter-spacing:0.06em;margin-bottom:4px;
}
.cert-logo-sub{font-size:11px;color:var(--text-muted);letter-spacing:0.04em;margin-bottom:20px}
.cert-divider{height:1px;background:var(--border-dim);margin:20px 0}
.cert-row{display:flex;justify-content:space-between;gap:16px;padding:6px 0;font-size:13px}
.cert-row-label{color:var(--text-muted)}
.cert-row-value{color:var(--text-primary);font-weight:500;text-align:right}
.cert-status{
  margin-top:20px;
  display:flex;align-items:center;gap:10px;
  background:var(--success-dim);border:1px solid rgba(45,155,107,0.2);
  border-radius:var(--r-md);padding:10px 14px;
}
.cert-status-dot{width:8px;height:8px;border-radius:50%;background:var(--success);flex-shrink:0}
.cert-status-text{font-size:13px;color:var(--success);font-weight:500}
.cert-ref{font-size:11px;color:var(--text-muted);margin-top:16px;letter-spacing:0.04em}

/* ─── SANYO SCALE ────────────────────────────────────── */
.scale-section{
  background:var(--bg-surface);
  border-top:1px solid var(--border-dim);
  border-bottom:1px solid var(--border-dim);
  padding:60px 0;
}
.scale-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:0}
@media(max-width:900px){.scale-grid{grid-template-columns:repeat(3,1fr)}}
@media(max-width:500px){.scale-grid{grid-template-columns:repeat(2,1fr)}}
.scale-item{
  padding:24px 20px;text-align:center;
  border-right:1px solid var(--border-dim);
}
.scale-item:last-child{border-right:none}
.scale-num{
  font-family:var(--font-display);font-size:32px;font-weight:700;
  color:var(--text-primary);line-height:1;margin-bottom:8px;
}
.scale-num .sn-val{color:var(--accent)}
.scale-label{font-size:12px;color:var(--text-muted);line-height:1.4}

/* ─── WHY SANYO ─────────────────────────────────────── */
.why-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
@media(max-width:900px){.why-grid{grid-template-columns:1fr 1fr}}
@media(max-width:580px){.why-grid{grid-template-columns:1fr}}
.why-card{
  background:var(--bg-surface);border:1px solid var(--border-dim);
  border-radius:var(--r-xl);padding:28px;
  transition:all var(--t-base);
  position:relative;
}
.why-card:hover{border-color:var(--accent-border);transform:translateY(-3px);background:var(--bg-raised)}
.why-icon{
  width:44px;height:44px;border-radius:var(--r-md);
  background:var(--accent-dim);border:1px solid var(--accent-border);
  display:flex;align-items:center;justify-content:center;
  margin-bottom:18px;font-size:20px;
}
.why-title{
  font-family:var(--font-display);font-size:14px;font-weight:500;
  color:var(--text-primary);margin-bottom:10px;line-height:1.3;
}
.why-desc{font-size:14px;color:var(--text-secondary);line-height:1.6}

/* ─── FIREFIGHTER SECTION ───────────────────────────── */
.fire-section{
  position:relative;overflow:hidden;
  background:var(--bg-surface);
  border-top:1px solid var(--border-dim);
  border-bottom:1px solid var(--border-dim);
  padding:80px 0;
}
.fire-bg{
  position:absolute;inset:0;pointer-events:none;
  background:radial-gradient(ellipse 50% 80% at 100% 50%, rgba(220,38,38,0.04) 0%, transparent 70%);
}
.fire-ghost{
  position:absolute;right:0;top:50%;
  font-family:var(--font-display);
  font-size:clamp(100px,18vw,240px);font-weight:700;
  color:transparent;-webkit-text-stroke:1px rgba(220,38,38,0.07);
  transform:translateY(-50%);pointer-events:none;user-select:none;
  line-height:1;white-space:nowrap;
  will-change:transform;
}
.fire-inner{position:relative;z-index:2;display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start}
@media(max-width:900px){.fire-inner{grid-template-columns:1fr}}
.fire-badge{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(220,38,38,0.1);border:1px solid rgba(220,38,38,0.25);
  padding:5px 14px;border-radius:99px;
  font-size:11px;color:#f87171;font-family:var(--font-display);
  letter-spacing:0.1em;font-weight:500;margin-bottom:24px;
}
.fire-specs{display:flex;flex-direction:column;gap:12px;margin-top:32px}
.spec-row{
  display:flex;align-items:center;gap:12px;
  padding:14px 16px;background:var(--bg-raised);
  border:1px solid var(--border-dim);border-radius:var(--r-md);
}
.spec-icon{
  width:36px;height:36px;border-radius:var(--r-sm);
  background:rgba(220,38,38,0.08);border:1px solid rgba(220,38,38,0.18);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
}
.spec-icon svg{width:16px;height:16px;color:#f87171}
.spec-label{font-size:12px;color:var(--text-muted);margin-bottom:2px}
.spec-value{font-size:14px;font-weight:500;color:var(--text-primary)}
.fire-certs{margin-top:32px}
.fire-cert-title{
  font-size:12px;color:var(--text-muted);letter-spacing:0.08em;
  text-transform:uppercase;font-family:var(--font-display);
  margin-bottom:14px;
}
.cert-list{display:flex;flex-direction:column;gap:8px}
.cert-item{
  display:flex;align-items:center;gap:10px;
  font-size:13px;color:var(--text-secondary);
}
.cert-check{
  width:18px;height:18px;border-radius:99px;flex-shrink:0;
  background:var(--success-dim);border:1px solid rgba(45,155,107,0.25);
  display:flex;align-items:center;justify-content:center;
}
.cert-check svg{width:10px;height:10px;color:var(--success)}
.ip-tags{display:flex;gap:8px;flex-wrap:wrap;margin-top:24px}
.ip-tag{
  font-family:var(--font-display);font-size:11px;font-weight:600;
  padding:4px 12px;border-radius:99px;letter-spacing:0.06em;
}
.ip-tag-red{background:rgba(220,38,38,0.1);color:#f87171;border:1px solid rgba(220,38,38,0.25)}
.ip-tag-blue{background:var(--info-dim);color:#60a5fa;border:1px solid var(--info-border)}

/* ─── PROJECTS ───────────────────────────────────────── */
.projects-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
@media(max-width:900px){.projects-grid{grid-template-columns:1fr 1fr}}
@media(max-width:580px){.projects-grid{grid-template-columns:1fr}}
.project-card{
  background:var(--bg-surface);border:1px solid var(--border-dim);
  border-radius:var(--r-xl);overflow:hidden;
  transition:all var(--t-base);
}
.project-card:hover{border-color:var(--border-default);transform:translateY(-3px)}
.project-img{
  height:140px;background:var(--bg-raised);
  display:flex;align-items:center;justify-content:center;
  font-size:40px;border-bottom:1px solid var(--border-dim);
  position:relative;overflow:hidden;
}
.project-img-bg{
  position:absolute;inset:0;
  background:linear-gradient(135deg,var(--bg-raised) 0%,var(--bg-subtle) 100%);
}
.project-img span{position:relative;z-index:1}
.project-body{padding:18px}
.project-name{
  font-family:var(--font-display);font-size:13px;font-weight:500;
  color:var(--text-primary);margin-bottom:6px;line-height:1.3;
}
.project-meta{font-size:12px;color:var(--text-muted)}
.project-flag{margin-right:5px}

/* ─── DELIVERIES TABLE ───────────────────────────────── */
.deliveries-section{background:var(--bg-surface);border-top:1px solid var(--border-dim);border-bottom:1px solid var(--border-dim);padding:80px 0}
.table-wrap{overflow-x:auto;margin-top:32px}
table{width:100%;border-collapse:collapse;font-size:14px}
thead tr{background:var(--bg-raised);border-bottom:1px solid var(--border-default)}
thead th{
  padding:12px 16px;text-align:left;
  font-family:var(--font-display);font-size:10px;font-weight:600;
  letter-spacing:0.12em;color:var(--text-muted);text-transform:uppercase;
}
tbody tr{border-bottom:1px solid var(--border-dim);transition:background var(--t-fast)}
tbody tr:hover{background:var(--bg-raised)}
tbody td{padding:14px 16px;color:var(--text-secondary)}
tbody td:first-child{color:var(--text-primary);font-weight:500}
.td-badge{
  display:inline-flex;font-size:11px;font-family:var(--font-display);
  font-weight:600;padding:3px 10px;border-radius:99px;letter-spacing:0.05em;
}
.badge-gov{background:rgba(37,99,235,0.1);color:#60a5fa;border:1px solid rgba(37,99,235,0.2)}
.badge-med{background:rgba(220,38,38,0.08);color:#f87171;border:1px solid rgba(220,38,38,0.18)}
.badge-ind{background:var(--accent-dim);color:var(--accent);border:1px solid var(--accent-border)}
.badge-culture{background:rgba(139,92,246,0.1);color:#a78bfa;border:1px solid rgba(139,92,246,0.2)}
.badge-telecom{background:rgba(34,197,94,0.1);color:#4ade80;border:1px solid rgba(34,197,94,0.2)}
.badge-intl{background:rgba(251,146,60,0.1);color:#fb923c;border:1px solid rgba(251,146,60,0.2)}

/* ─── CERTIFICATE CTA ────────────────────────────────── */
.cert-cta{
  background:var(--bg-surface);border:1px solid var(--border-dim);
  border-radius:var(--r-2xl);padding:48px;
  display:grid;grid-template-columns:1fr auto;gap:32px;align-items:center;
  position:relative;overflow:hidden;margin:0 0 80px;
}
.cert-cta::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--accent)}
.cert-cta-glow{position:absolute;right:-80px;top:-80px;width:300px;height:300px;background:radial-gradient(circle,rgba(212,135,14,0.05) 0%,transparent 70%);pointer-events:none}
.cert-cta-title{font-family:var(--font-display);font-size:20px;font-weight:600;color:var(--text-primary);margin-bottom:8px}
.cert-cta-sub{font-size:14px;color:var(--text-secondary);max-width:480px;line-height:1.6}
@media(max-width:700px){.cert-cta{grid-template-columns:1fr}.cert-cta-actions{display:flex;gap:12px;flex-wrap:wrap}}

/* ─── PARALLAX ───────────────────────────────────────── */
.prl{will-change:transform}

/* ─── STAT SUFFIXES ──────────────────────────────────── */
.sn-sfx{color:var(--text-primary)}
</style>

<script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type":"ListItem","position":1,"name":"Главная","item":"https://delta-elevators.ru"},
        {"@type":"ListItem","position":2,"name":"Лифты SANYO","item":"https://delta-elevators.ru/sanyo/"}
      ]
    },
    {
      "@type": "Product",
