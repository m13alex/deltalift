  }, { passive: true });

  function run() {
    var sy = window.scrollY;
    if (pg) pg.style.transform = 'translateY(' + (sy * 0.14) + 'px)';
    if (prlFire) {
      var r = prlFire.closest('.fire-section');
      if (r) {
        var rect = r.getBoundingClientRect();
        var p = (window.innerHeight - rect.top) / (window.innerHeight + rect.height);
        prlFire.style.transform = 'translateY(calc(-50% + ' + ((p - 0.5) * 80) + 'px))';
      }
    }
    tick = false;
  }
  run();

  // ── MOUSE PARALLAX on HERO ────────────────────────────
  var hero = document.querySelector('.hero');
  if (hero) {
    hero.addEventListener('mousemove', function(e) {
      var rx = (e.clientX / window.innerWidth - 0.5) * 16;
      var ry = (e.clientY / window.innerHeight - 0.5) * 16;
      if (pg) pg.style.transform = 'translate(' + (rx * 0.3) + 'px, ' + (ry * 0.3) + 'px)';
    });
    hero.addEventListener('mouseleave', function() { if (pg) pg.style.transform = ''; });
  }
});
</script>

<ThemeToggleScript />
<FadeInScript />

</BaseLayout>
